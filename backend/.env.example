# Database — PostgreSQL (Neon)
# Neon provides a connection string with sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/gymbuddy?sslmode=require

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Server (Railway provides PORT automatically)
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS — update with your deployed frontend URL)
FRONTEND_URL=https://your-frontend-domain.pages.dev

# Midtrans (Sandbox)
MIDTRANS_SERVER_KEY=SB-Mid-server-your-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-key
MIDTRANS_IS_PRODUCTION=false
